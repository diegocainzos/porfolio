---
const personalImageAlt = "Miguel Ángel"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16"
      src="./photo.png"
      alt={personalImageAlt}
    />
    <a
      href="https://linkedin.com/in/diegocainzos"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Open to work</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    Hey, I'm Diego 👋
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >

    Seasoned <strong>Computer Engineer</strong> specializing in robust <strong>Software Development</strong> solutions and advanced <strong>Machine Learning</strong> deployment, focused primarily on <strong>NLP and Large Language Models (LLMs)</strong>. 
    
    <br><br>

    Strong <strong>international experience</strong> and professional <strong>trilingual proficiency (ES/EN/PT)</strong>. Seeking challenging, <strong>Full-Time</strong> roles starting <strong>immediately</strong>. Ready to contribute to your global team (Remote/Relocation Flexible).

  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="mailto:digarca02@gmail.com">
      <MailIcon class="size-4" />
      Reach me
    </SocialPill>
    <SocialPill href="https://linkedin.com/in/diegocainzos">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
  </nav>
</div>
